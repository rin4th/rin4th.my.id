---
import Layout from "@/layouts/Layout.astro";
import TableOfContents from "@/components/TableOfContents.svelte";
import { getCollection, render } from "astro:content";
import type { TocHeading } from "@/types";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, excerpt, tags, coverImage } = post.data;
const { Content, headings } = await render(post);

const formattedDate = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(date);

const tocHeadings: TocHeading[] = headings
  .filter((h) => h.depth <= 3)
  .map((h) => ({
    depth: h.depth,
    slug: h.slug,
    text: h.text,
  }));
---

<Layout title={title} description={excerpt}>
  <div class="max-w-6xl mx-auto px-4 md:px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_240px] gap-10 items-start">
      <!-- Main content -->
      <article class="min-w-0">
        <!-- Back link -->
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-sm mb-8 transition-colors duration-200"
          style="color: #71717a;"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back to Blog
        </a>

        <!-- Cover image -->
        {
          coverImage && (
            <div class="mb-8 rounded-xl overflow-hidden border" style="border-color: #333;">
              <img src={coverImage} alt={title} class="w-full object-cover max-h-80" />
            </div>
          )
        }

        <!-- Meta -->
        <div class="mb-6">
          {
            tags && tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mb-4">
                {tags.map((tag) => (
                  <span
                    class="px-2 py-0.5 rounded text-xs font-mono"
                    style="background: rgba(163,230,53,0.08); color: #a3e635; border: 1px solid rgba(163,230,53,0.2);"
                  >
                    #{tag}
                  </span>
                ))}
              </div>
            )
          }

          <h1 class="text-3xl md:text-4xl font-bold mb-3 leading-tight" style="color: #f4f4f5;">
            {title}
          </h1>

          <div class="flex items-center gap-2 text-sm font-mono" style="color: #71717a;">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            {formattedDate}
          </div>
        </div>

        <!-- Divider -->
        <div class="h-px mb-8" style="background: #333;"></div>

        <!-- Content -->
        <div class="prose max-w-none">
          <Content />
        </div>

        <!-- Tags footer -->
        {
          tags && tags.length > 0 && (
            <div class="mt-12 pt-8 border-t" style="border-color: #333;">
              <p class="text-sm mb-3" style="color: #71717a;">
                Tagged under:
              </p>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <a
                    href={`/blog?tag=${tag}`}
                    class="px-3 py-1 rounded-lg text-sm font-mono transition-colors duration-200"
                    style="background: #2d2d2d; color: #a1a1aa; border: 1px solid #3d3d3d;"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </article>

      <!-- Table of Contents (sidebar) -->
      {
        tocHeadings.length > 0 && (
          <aside class="hidden lg:block sticky top-24 self-start">
            <TableOfContents headings={tocHeadings} client:idle />
          </aside>
        )
      }
    </div>
  </div>
</Layout>
