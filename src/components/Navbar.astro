---
import MobileMenu from "./MobileMenu.svelte";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" },
  { label: "Write Up", href: "/writeup" },
  { label: "Project", href: "/project" },
  { label: "About", href: "/about" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b"
  style="background-color: rgba(30,30,30,0.92); backdrop-filter: blur(12px); border-color: #333;"
>
  <nav class="max-w-6xl mx-auto px-4 md:px-6 flex items-center justify-between h-16">
    <!-- Logo -->
    <a
      href="/"
      class="font-mono font-bold text-lg tracking-tight flex items-center gap-1.5"
      style="color: #a3e635;"
    >
      <span style="color: #a1a1aa;">~/</span>rin4th
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-1">
      {
        navLinks.map((link) => {
          const isActive =
            link.href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(link.href);
          return (
            <li>
              <a
                href={link.href}
                class="px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200"
                style={
                  isActive
                    ? "color: #a3e635; background-color: rgba(163,230,53,0.1);"
                    : "color: #a1a1aa;"
                }
                aria-current={isActive ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- Mobile Menu Button -->
    <MobileMenu navLinks={navLinks} client:load />
  </nav>
</header>
