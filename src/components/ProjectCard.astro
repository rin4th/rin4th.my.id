---
import type { Project } from "@/types";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { title, description, previewImage, techStack, githubUrl, liveUrl } = project.data;
---

<article
  class="group relative rounded-xl border overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1"
  style="background: #252525; border-color: #333;"
>
  <!-- Preview Image -->
  <div class="h-44 overflow-hidden flex-shrink-0" style="background: #2d2d2d;">
    <img
      src={previewImage}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  </div>

  <div class="p-5 flex flex-col flex-1">
    <!-- Title -->
    <h3 class="font-bold text-base mb-2 leading-snug" style="color: #f4f4f5;">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm mb-4 leading-relaxed flex-1 line-clamp-3" style="color: #a1a1aa;">
      {description}
    </p>

    <!-- Tech Stack -->
    {
      techStack.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {techStack.map((tech) => (
            <span
              class="px-2 py-0.5 rounded text-xs font-mono"
              style="background: #2d2d2d; color: #a1a1aa; border: 1px solid #3d3d3d;"
            >
              {tech}
            </span>
          ))}
        </div>
      )
    }

    <!-- Links -->
    <div class="flex items-center gap-3 mt-auto">
      {
        githubUrl && (
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-medium transition-colors duration-200"
            style="color: #a1a1aa;"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
            GitHub
          </a>
        )
      }
      {
        liveUrl && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-medium transition-colors duration-200"
            style="color: #a3e635;"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
            Live Demo
          </a>
        )
      }
    </div>
  </div>

  <!-- Hover accent line -->
  <div
    class="absolute bottom-0 left-0 h-0.5 w-0 group-hover:w-full transition-all duration-300"
    style="background: #a3e635;"
  >
  </div>
</article>
