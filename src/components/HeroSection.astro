---
---

<section class="relative pt-20 pb-24 px-4 md:px-6 overflow-hidden">
  <!-- Background grid pattern -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="
      background-image:
        linear-gradient(rgba(163,230,53,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(163,230,53,0.03) 1px, transparent 1px);
      background-size: 60px 60px;
    "
  >
  </div>

  <!-- Glow -->
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(163,230,53,0.06) 0%, transparent 70%);"
  >
  </div>

  <div class="relative max-w-6xl mx-auto">
    <div class="max-w-3xl">
      

      <!-- Name -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4 leading-tight">
        <span style="color: #f4f4f5;">Hi, I'm </span>
        <span
          style="
            color: #a3e635;
            text-shadow: 0 0 40px rgba(163,230,53,0.4);
          ">Rin4th</span
        >
      </h1>

      <!-- Tagline -->
      <p class="text-lg md:text-xl mb-3 font-mono" style="color: #a3e635;">
        A Software Developer &amp; Cyber Security Enthusiast!
      </p>

      <!-- Status badge -->
      <div class="inline-flex items-center gap-2 mb-6">
        <span
          class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-mono border"
          style="background: rgba(163,230,53,0.08); border-color: rgba(163,230,53,0.25); color: #a3e635;"
        >
          $ hack: cannot hack 'life': Operation not permitted
        </span>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-3">
        <a
          href="/cv.pdf"
          download
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-sm transition-all duration-200 hover:scale-105"
          style="background: #a3e635; color: #1e1e1e;"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download CV
        </a>
        <a
          href="https://www.linkedin.com/in/rizal-nur-arbaatun"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-semibold text-sm border transition-all duration-200 hover:scale-105"
          style="border-color: #a3e635; color: #a3e635; background: transparent;"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>
