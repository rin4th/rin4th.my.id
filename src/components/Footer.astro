---
const year = new Date().getFullYear();

const socials = [
  { label: "GitHub", href: "https://github.com/rin4th" },
  { label: "LinkedIn", href: "https://linkedin.com/in/rin4th" },
];
---

<footer class="border-t mt-16" style="border-color: #333; background-color: #1e1e1e;">
  <div class="max-w-6xl mx-auto px-4 md:px-6 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span class="font-mono text-sm" style="color: #71717a;">
          © {year}
          <span style="color: #a3e635;">rin4th</span> — built with
          <a
            href="https://astro.build"
            target="_blank"
            rel="noopener noreferrer"
            class="underline-offset-2 hover:underline"
            style="color: #a1a1aa;">Astro</a
          >
        </span>
      </div>
      <div class="flex items-center gap-4">
        {
          socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm transition-colors duration-200 hover:text-accent"
              style="color: #71717a;"
            >
              {s.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
