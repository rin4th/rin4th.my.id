---
interface Props {
  totalWriteups: number;
}

const { totalWriteups } = Astro.props;
---

<div
  class="rounded-xl border p-5"
  style="background: #252525; border-color: #333;"
>
  <h2
    class="text-xs font-mono font-semibold tracking-widest uppercase mb-4"
    style="color: #a3e635;"
  >
    ▸ NODE STATS
  </h2>

  <div class="space-y-3">
    <div class="flex items-center justify-between">
      <span class="text-sm" style="color: #a1a1aa;">Total Write Ups</span>
      <span
        class="font-mono font-bold text-sm px-2 py-0.5 rounded"
        style="background: rgba(163,230,53,0.1); color: #a3e635;"
      >
        {totalWriteups}
      </span>
    </div>

    <div class="h-px" style="background: #333;"></div>

    <div class="flex items-center justify-between">
      <span class="text-sm" style="color: #a1a1aa;">Current Grinding</span>
      <span
        class="font-mono font-bold text-xs px-2 py-0.5 rounded border"
        style="color: #f59e0b; border-color: rgba(245,158,11,0.3); background: rgba(245,158,11,0.08);"
      >
        HackTheBox
      </span>
    </div>
  </div>
</div>
